# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartx?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Twitter/X OAuth 2.0
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_CALLBACK_URL="http://localhost:3000/auth/x/callback"

# OpenAI
OPENAI_API_KEY=""

# App
PORT=3000
NODE_ENV="development"
